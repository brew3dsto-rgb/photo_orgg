# =============================================================================
# Immich Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   nano .env
# =============================================================================

# ---- Immich Version ----
# Pin to a specific version or use 'release' for latest stable
IMMICH_VERSION=release

# ---- Storage Locations ----
# Where uploaded photos/videos are stored (use your largest drive)
UPLOAD_LOCATION=/srv/immich/photos

# Where PostgreSQL data is stored (MUST be on local SSD, not NFS/NAS)
DB_DATA_LOCATION=/srv/immich/pgdata

# ---- Database Credentials ----
# Generate a strong password: openssl rand -base64 32
DB_PASSWORD=CHANGE_ME_TO_SOMETHING_SECURE
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

# ---- NSFW Sidecar Configuration ----
# Generate an API key in Immich: Profile > Account Settings > API Keys
# The sidecar uses this to tag photos and manage the NSFW album
NSFW_SIDECAR_API_KEY=YOUR_IMMICH_API_KEY_HERE

# Confidence threshold (0.0-1.0) — higher = fewer false positives
# 0.75 is a good starting point; raise to 0.85+ if you get too many false tags
NSFW_THRESHOLD=0.75

# Name of the album that NSFW-flagged photos get added to
NSFW_ALBUM_NAME=NSFW

# How often (seconds) the sidecar checks for new unprocessed assets
NSFW_POLL_INTERVAL=30
